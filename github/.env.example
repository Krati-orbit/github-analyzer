# Google Gemini API Key for Profile Analysis (Get one from Google AI Studio)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: GitHub Personal Access Token (to prevent public API rate limits)
VITE_GITHUB_TOKEN=your_github_token_here

# Default GitHub user to profile automatically on load
VITE_DEFAULT_GITHUB_USER=Krati-orbit

# Creator/Owner Dossier details for the "About Developer" info drawer
VITE_CREATOR_NAME=Krati
VITE_CREATOR_ROLE="Full-Stack Developer & Solutions Architect"
VITE_CREATOR_BIO="Building intelligent, high-performance web applications. Specialized in TypeScript, React, Node.js, and Cognitive AI Integrations."
VITE_CREATOR_EMAIL=your_email@example.com
VITE_CREATOR_LINKEDIN=https://linkedin.com/in/yourprofile
VITE_CREATOR_WEBSITE=https://github.com/Krati-orbit
VITE_CREATOR_RESUME_URL=

